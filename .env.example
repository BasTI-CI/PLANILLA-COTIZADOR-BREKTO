# En Supabase: Project URL y anon (publishable) — en Vite: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# o: VITE_SUPABASE_PUBLISHABLE_KEY=  (misma clave pública)

# SSO: desplegar Edge Function `validate-cotizador-access`; sin bypass en local: VITE_DEV_BYPASS_AUTH=false
# VITE_COTIZADOR_SESSION_MAX_MS=28800000

# Stock: `imagina` = tabla Stock_Imagina_Prueba + mock sin env
#         `definitivo` = schema en src/lib/stock/definitivo/schema.ts
#         (omitir) = tablas public.proyectos + public.inmobiliarias
# VITE_STOCK_BACKEND=imagina
